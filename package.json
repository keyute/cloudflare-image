      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsdown": "0.21.10",
    "typescript": "6.0.3"
  },
  "keywords": [
    "cloudflare",
    "image",
    "typescript",
    "react"
  ]
}
