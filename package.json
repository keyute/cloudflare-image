  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/keyute/cloudflare-image.git"
  },
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
